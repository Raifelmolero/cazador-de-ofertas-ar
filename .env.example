# ─── Mercado Libre ────────────────────────────────────────────────────────────
ML_BASE_URL=https://www.mercadolibre.com.ar
ML_SEED_SEARCH_URL=https://listado.mercadolibre.com.ar/tendencias

# ─── Afiliados ────────────────────────────────────────────────────────────────
# Registrate en https://partners.mercadolibre.com.ar
# Pegá tu Publisher ID (número o string que te dan al registrarte).
# Si está vacío, las URLs se guardan sin parámetro de afiliado.
ML_AFFILIATE_ID=

# ─── Scraper (opcional) ───────────────────────────────────────────────────────
HEADLESS=1
NAV_TIMEOUT_MS=45000
MAX_PRODUCTS=50
MAX_PAGES=5
MIN_DELAY_S=0.8
MAX_DELAY_S=2.2
OUTPUT_JSON_PATH=frontend/data/productos_rentables.json
